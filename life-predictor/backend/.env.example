DATABASE_URL=postgresql://user:password@localhost:5432/lifepredictor
ADMIN_PASSWORD=your_admin_password_here
# Optional. Must be an OpenAI-compatible chat completions endpoint.
# Leave these blank to skip AI report generation.
AI_API_BASE_URL=
AI_API_KEY=
AI_MODEL=
PORT=3001
FRONTEND_URL=http://localhost:5173
PUBLIC_SITE_URL=https://your-domain.example
NODE_ENV=development

# Optional email (SMTP). Works with any SMTP provider: Resend, Amazon SES,
# Aliyun/Tencent DirectMail, SendGrid, Gmail, etc. Leave blank to disable email
# (lead capture still works, it just won't send confirmation/recovery mail).
# Port 465 = SMTPS, 587 = STARTTLS.
EMAIL_SMTP_HOST=
EMAIL_SMTP_PORT=587
EMAIL_SMTP_USER=
EMAIL_SMTP_PASS=
EMAIL_FROM=LifeScore <noreply@your-domain.example>
